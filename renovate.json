{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>SchweizerischeBundesbahnen/casc-renovate-preset-polarion-docker"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "pep621"
      ],
      "matchDatasources": [
        "pypi"
      ],
      "semanticCommitType": "fix",
      "matchUpdateTypes": [
        "patch"
      ]
    }
  ]
}
